# 환경변수 예시 — 실제 .env 에 복사 후 값 채우기.
# ⚠️ VITE_ prefix 는 클라이언트 번들에 포함됨 (공개 OK 인 값만)
# ⚠️ service_role / OAuth secret / Stripe secret 등은 절대 여기 안 됨

# Supabase — 모두 공개 가능 (anon 키)
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGciOiJIUzI1NiI..."
VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT"

# RevenueCat — Public SDK Key (공개 OK, RevenueCat 대시보드에서 발급)
# https://app.revenuecat.com → Project Settings → API Keys → Public app-specific keys
# iOS / Android 별도 키:
VITE_REVENUECAT_IOS_KEY="appl_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
VITE_REVENUECAT_ANDROID_KEY="goog_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
